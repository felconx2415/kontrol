# Variables para docker compose (cópialo a `.env` junto al docker-compose.yml).
# docker compose las lee para interpolar y se las pasa al contenedor.

# Secreto de sesión: OBLIGATORIO, mínimo 32 caracteres.
# Genera uno con:  openssl rand -base64 32
SESSION_SECRET=

# Cuenta admin inicial (se crea en el primer arranque). Cambia la contraseña.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_NOMBRE=Administrador

# Solo si usas la variante "Caddy en el host": puerto local a publicar.
# (Con Caddy en Docker no se publica ningún puerto.)
KONTROL_HOST_PORT=8087
