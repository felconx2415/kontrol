// Kontrol — gestión de solicitudes y entrega de equipamiento y EPP.
// El flujo de solicitudes NO controla inventario: ese stock vive en un almacén
// externo y aquí solo se registra el ciclo de vida de cada solicitud.
//
// Aparte de ese flujo existe la Bodega local (ItemBodega / MovimientoBodega /
// Prestamo): un inventario físico que SÍ se gestiona dentro de Kontrol, del que
// se saca material en forma definitiva o se presta con devolución.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Rol {
  SOLICITANTE
  APROBADOR
  GESTOR
  ADMIN
}

enum Categoria {
  EQUIPAMIENTO
  EPP
}

enum TipoSolicitud {
  NUEVO
  REEMPLAZO
}

enum EstadoSolicitud {
  BORRADOR
  PENDIENTE
  APROBADA
  RECHAZADA
  EN_GESTION
  RECIBIDA
  ENTREGADA
  CANCELADA
}

// Motivo de cada ítem solicitado. Alimenta la columna «Estado» del formato que
// se envía al almacén. Se agrupa por tipo de solicitud (ver MOTIVOS_NUEVO y
// MOTIVOS_REEMPLAZO en lib/solicitud-estado.ts).
enum Motivo {
  // Reemplazo (algo que ya se tenía)
  DESGASTE // Desgaste por uso
  EXTRAVIO // Extraviado (a)
  HURTO_MOVIL // Hurto desde el móvil
  PERDIDA_SINIESTRO // Pérdida por siniestro
  ROBO_MOVIL // Robo de móvil
  VENCIMIENTO_CERT // Vencida certificación
  // Material nuevo
  NUEVA_INCORPORACION // Nueva incorporación
  PRIMERA_VEZ // Solicitado por primera vez
  STOCK_FRONTEL // Stock Frontel
}

enum TipoBrigada {
  EMPRESA
  CONTRATISTA
}

enum TipoMovimiento {
  ENTRADA // ingreso o reposición de stock
  SALIDA // retiro definitivo (consumo)
  PRESTAMO // salida temporal con devolución esperada
  DEVOLUCION // reingreso de un préstamo
  AJUSTE // corrección manual del stock a un valor absoluto
}

enum EstadoPrestamo {
  ACTIVO
  DEVUELTO
}

model Usuario {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  nombre       String
  rut          String?
  rol          Rol      @default(SOLICITANTE)
  brigadaId    String?
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  brigada              Brigada?  @relation("MiembrosBrigada", fields: [brigadaId], references: [id])
  brigadasSupervisadas Brigada[] @relation("SupervisorBrigada")

  solicitudesCreadas     Solicitud[] @relation("Solicitante")
  solicitudesAprobadas   Solicitud[] @relation("Aprobador")
  solicitudesGestionadas Solicitud[] @relation("Gestor")
  solicitudesEditadas    Solicitud[] @relation("EditorSolicitud")

  entregasRecibidas Entrega[] @relation("Receptor")
  entregasHechas    Entrega[] @relation("EntregadoPor")

  auditorias Auditoria[]

  // Bodega local
  movimientosBodega    MovimientoBodega[]
  prestamosRegistrados Prestamo[]

  @@index([rol])
}

model Brigada {
  id           String      @id @default(cuid())
  nombre       String      @unique
  // Empresa o contratista: define en qué columna del formato de almacén va el
  // nombre de la brigada (la otra queda en «-»).
  tipo         TipoBrigada @default(EMPRESA)
  supervisorId String?

  supervisor  Usuario?    @relation("SupervisorBrigada", fields: [supervisorId], references: [id])
  miembros    Usuario[]   @relation("MiembrosBrigada")
  solicitudes Solicitud[]
}

model Articulo {
  id            String    @id @default(cuid())
  codigo        String    @unique
  nombre        String
  categoria     Categoria
  unidad        String    @default("unidad")
  // Centro de costo (CECO) del codigario; opcional para ítems creados a mano.
  ceco          String?
  // Días de vida útil del EPP; si es null el ítem no vence.
  vidaUtilDias  Int?
  activo        Boolean   @default(true)

  items SolicitudItem[]

  @@index([categoria])
}

model Solicitud {
  id            String          @id @default(cuid())
  folio         Int             @unique
  solicitanteId String
  brigadaId     String?
  tipo          TipoSolicitud
  estado        EstadoSolicitud @default(BORRADOR)
  justificacion String?
  creadaEn      DateTime        @default(now())

  enviadaEn     DateTime?
  aprobadorId   String?
  aprobadaEn    DateTime?
  motivoRechazo String?

  // Ajuste hecho por el aprobador antes de aprobar. Se guarda aparte de la
  // auditoría para poder mostrarle al solicitante que su pedido cambió.
  editadaEn   DateTime?
  editadaPorId String?

  gestorId         String?
  // Referencia manual del pedido hecho al almacén externo.
  pedidoExternoRef String?
  enGestionEn      DateTime?
  recibidaEn       DateTime?

  canceladaEn DateTime?

  solicitante Usuario  @relation("Solicitante", fields: [solicitanteId], references: [id])
  aprobador   Usuario? @relation("Aprobador", fields: [aprobadorId], references: [id])
  gestor      Usuario? @relation("Gestor", fields: [gestorId], references: [id])
  editadaPor  Usuario? @relation("EditorSolicitud", fields: [editadaPorId], references: [id])
  brigada     Brigada? @relation(fields: [brigadaId], references: [id])

  items   SolicitudItem[]
  entrega Entrega?

  @@index([estado])
  @@index([solicitanteId])
}

model SolicitudItem {
  id          String  @id @default(cuid())
  solicitudId String
  articuloId  String
  cantidad    Int     @default(1)
  // Cantidad realmente recibida del almacén al marcar la solicitud como
  // recibida. Puede ser menor a la pedida (a veces no llega todo). Null
  // mientras no se ha recibido; al marcar recibida se fija por ítem.
  cantidadRecibida Int?

  // Motivo del ítem (todas las solicitudes lo llevan; ver enum Motivo).
  motivo           Motivo?
  detalleReemplazo String?
  fotoEvidenciaUrl String?
  // Trazabilidad: el EntregaItem que este ítem viene a reemplazar.
  entregaAnteriorItemId String? @unique

  solicitud       Solicitud    @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  articulo        Articulo     @relation(fields: [articuloId], references: [id])
  entregaAnterior EntregaItem? @relation("CadenaReemplazo", fields: [entregaAnteriorItemId], references: [id])

  entregaItem EntregaItem? @relation("ItemEntregado")

  @@index([solicitudId])
}

model Entrega {
  id             String   @id @default(cuid())
  solicitudId    String   @unique
  receptorId     String
  entregadoPorId String
  entregadaEn    DateTime @default(now())
  firmaPngUrl    String
  observaciones  String?
  actaPdfUrl     String?

  solicitud    Solicitud @relation(fields: [solicitudId], references: [id])
  receptor     Usuario   @relation("Receptor", fields: [receptorId], references: [id])
  entregadoPor Usuario   @relation("EntregadoPor", fields: [entregadoPorId], references: [id])

  items EntregaItem[]

  @@index([receptorId])
}

model EntregaItem {
  id                String    @id @default(cuid())
  entregaId         String
  solicitudItemId   String    @unique
  cantidadEntregada Int
  // Fecha de vencimiento calculada desde Articulo.vidaUtilDias al entregar.
  venceEn           DateTime?
  // Se marca cuando un reemplazo posterior deja este ítem fuera de uso.
  reemplazadoEn     DateTime?

  entrega       Entrega       @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  solicitudItem SolicitudItem @relation("ItemEntregado", fields: [solicitudItemId], references: [id])

  reemplazadoPor SolicitudItem? @relation("CadenaReemplazo")

  @@index([entregaId])
  @@index([venceEn])
}

model Auditoria {
  id          String   @id @default(cuid())
  usuarioId   String
  entidad     String
  entidadId   String
  accion      String
  detalleJson String?
  creadoEn    DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([entidad, entidadId])
  @@index([creadoEn])
}

// Contador de folio correlativo para las solicitudes.
model Contador {
  nombre String @id
  valor  Int    @default(0)
}

// ── Bodega local ──────────────────────────────────────────────────────────
// Inventario físico gestionado dentro de Kontrol, independiente del catálogo
// de solicitudes. `stock` es el número de unidades disponibles ahora mismo:
// baja al sacar o prestar y sube al ingresar o al devolverse un préstamo.

model ItemBodega {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  categoria String   @default("General")
  unidad    String   @default("unidad")
  ubicacion String?
  stock     Int      @default(0)
  notas     String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  movimientos MovimientoBodega[]
  prestamos   Prestamo[]

  @@index([activo])
}

model MovimientoBodega {
  id       String         @id @default(cuid())
  itemId   String
  tipo     TipoMovimiento
  // Unidades del movimiento. Para AJUSTE guarda el nuevo stock absoluto; para
  // el resto es siempre positivo y el signo lo determina `tipo`.
  cantidad Int
  // Stock del ítem tras aplicar el movimiento (foto para auditoría).
  stockResultante Int
  // A quién se entregó o prestó. Texto libre: puede no ser usuario del sistema.
  persona    String?
  notas      String?
  // Quién registró el movimiento en Kontrol.
  usuarioId  String
  // Préstamo asociado, cuando el movimiento es PRESTAMO o DEVOLUCION.
  prestamoId String?
  creadoEn   DateTime @default(now())

  item     ItemBodega @relation(fields: [itemId], references: [id], onDelete: Cascade)
  usuario  Usuario    @relation(fields: [usuarioId], references: [id])
  prestamo Prestamo?  @relation(fields: [prestamoId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([creadoEn])
}

model Prestamo {
  id            String         @id @default(cuid())
  itemId        String
  cantidad      Int
  persona       String
  estado        EstadoPrestamo @default(ACTIVO)
  notas         String?
  prestadoPorId String
  prestadoEn    DateTime       @default(now())
  devueltoEn    DateTime?

  // Acta firmada: la firma de salida se toma al prestar y la de devolución al
  // recibir de vuelta. Ambas son PNG guardados como archivo. Nullable para no
  // romper préstamos previos al acta.
  firmaSalidaUrl        String?
  firmaDevolucionUrl    String?
  observacionesDevolucion String?
  // Fotos de daños al devolver, como arreglo JSON de rutas públicas.
  fotosDevolucion       String?

  item        ItemBodega         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  prestadoPor Usuario            @relation(fields: [prestadoPorId], references: [id])
  movimientos MovimientoBodega[]

  @@index([estado])
  @@index([itemId])
}
